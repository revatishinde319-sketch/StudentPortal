@{
}
@model List<StudentPortal.Models.Student>

<H1>Student List</H1>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var Student in Model)
        {
            <tr>
                <td>@Student.Name</td>
                <td>@Student.Email</td>
                <td>@Student.Phone</td>
                <td><a class="btn btn-primary" asp-action="Edit" asp-controller="Student" asp-route-id="@Student.Id">Edit</a></td>
                
                
            </tr>
            
        }
        
    </tbody>
</table>